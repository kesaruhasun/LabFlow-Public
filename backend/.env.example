# Gemini AI Configuration (Get an API key from https://aistudio.google.com/)
GEMINI_API_KEY="your-gemini-api-key"

# Telegram Bot Configuration (Optional, for notifications)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Security Keys
CHALLENGE_SECRET="labflow-ai-challenge-secret"
APP_VERIFICATION_TOKEN="labflow-app-v1-secret"

# Google Cloud Platform (Only required if using Vertex AI backend)
GOOGLE_CLOUD_PROJECT_ID="your-project-id"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/service-account-key.json"
